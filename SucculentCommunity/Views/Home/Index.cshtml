@using System.Text.RegularExpressions
@model IEnumerable<SucculentCommunity.Models.Post>

@{
    ViewData["Title"] = "首頁 - 動態牆";
}

<div class="container mt-4 mb-5">

    <div class="d-flex flex-wrap justify-content-between align-items-center mb-4 pb-3 border-bottom gap-3">
        <div>
            <h2 class="fw-bold mb-1" style="color: #5C8A8A;">🪴 歡迎來到小肉肉園地</h2>
            <p class="text-muted small mb-0">在這裡，紀錄每一次發芽的喜悅，分享每一片葉子的故事。</p>
        </div>

        @if (User.Identity.IsAuthenticated)
        {
            <a asp-controller="Posts" asp-action="Create" class="btn rounded-pill px-4 py-2 fw-bold shadow-sm text-white"
               style="background-color: #5C8A8A; transition: transform 0.2s, box-shadow 0.2s;"
               onmouseover="this.style.transform='translateY(-3px)'; this.style.boxShadow='0 8px 15px rgba(92, 138, 138, 0.3)';"
               onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='0 .125rem .25rem rgba(0,0,0,.075)';">
                ✍️ 寫新貼文
            </a>
        }
    </div>

    @if (ViewBag.LatestAnnouncement != null)
    {
        var ann = ViewBag.LatestAnnouncement as SucculentCommunity.Models.Announcement;
        <div class="row justify-content-center mb-5">
            <div class="col-md-8">
                <a href="/Announcements/Details/@ann.AnnounceID" class="text-decoration-none">
                    <div class="alert rounded-pill shadow-sm d-flex align-items-center justify-content-between px-4 py-3" style="background-color: #E6F2F2; border: 1px solid #B8D8BA; transition: transform 0.2s;" onmouseover="this.style.transform='translateY(-2px)'" onmouseout="this.style.transform='translateY(0)'">
                        <div class="d-flex align-items-center text-truncate pe-3">
                            <span class="badge bg-white text-secondary me-3 shadow-sm px-3 py-2 border">📢 最新公告</span>
                            <span class="fw-bold text-truncate" style="color: #4A6B6B;">@ann.Title</span>
                        </div>
                        <small class="text-muted text-nowrap d-none d-md-block fw-bold">@ann.PostTime.ToString("yyyy/MM/dd")</small>
                    </div>
                </a>
            </div>
        </div>
    }

    <ul class="nav nav-pills mb-5 justify-content-center gap-2 gap-md-3 custom-tabs" id="pills-tab" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link active rounded-pill fw-bold px-3 px-md-4 shadow-sm" id="pills-all-tab" data-bs-toggle="pill" data-bs-target="#pills-all" type="button" role="tab" aria-selected="true">
                🌟 最新動態
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link rounded-pill fw-bold px-3 px-md-4 shadow-sm" id="pills-ask-tab" data-bs-toggle="pill" data-bs-target="#pills-ask" type="button" role="tab" aria-selected="false">
                ❓ 舉手發問
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link rounded-pill fw-bold px-3 px-md-4 shadow-sm" id="pills-diary-tab" data-bs-toggle="pill" data-bs-target="#pills-diary" type="button" role="tab" aria-selected="false">
                📖 多肉日誌
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link rounded-pill fw-bold px-3 px-md-4 shadow-sm" id="pills-tips-tab" data-bs-toggle="pill" data-bs-target="#pills-tips" type="button" role="tab" aria-selected="false">
                ✨ 養護心得
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link rounded-pill fw-bold px-3 px-md-4 shadow-sm text-danger border-danger" id="pills-hot-tab" data-bs-toggle="pill" data-bs-target="#pills-hot" type="button" role="tab" aria-selected="false" style="background-color: #FFF5F5;">
                🔥 熱門精選
            </button>
        </li>
    </ul>

    <div class="tab-content" id="pills-tabContent">
        <div class="tab-pane fade show active" id="pills-all" role="tabpanel" aria-labelledby="pills-all-tab">
            <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
                @foreach (var item in Model) { await RenderPostCard(item); }
            </div>
        </div>
        <div class="tab-pane fade" id="pills-ask" role="tabpanel" aria-labelledby="pills-ask-tab">
            <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
                @foreach (var item in Model.Where(p => p.PostType == "1")) { await RenderPostCard(item); }
            </div>
        </div>
        <div class="tab-pane fade" id="pills-diary" role="tabpanel" aria-labelledby="pills-diary-tab">
            <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
                @foreach (var item in Model.Where(p => p.PostType == "2")) { await RenderPostCard(item); }
            </div>
        </div>
        <div class="tab-pane fade" id="pills-tips" role="tabpanel" aria-labelledby="pills-tips-tab">
            <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
                @foreach (var item in Model.Where(p => p.PostType == "3")) { await RenderPostCard(item); }
            </div>
        </div>
        <div class="tab-pane fade" id="pills-hot" role="tabpanel" aria-labelledby="pills-hot-tab">
            <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
                @{
                    var hotPosts = Model.OrderByDescending(p => p.PostLikes?.Count ?? 0).ThenByDescending(p => p.CreatedTime).Take(9);
                }
                @foreach (var item in hotPosts) { await RenderPostCard(item); }
            </div>
        </div>
    </div>
</div>

@{
    // ==========================================
    // 🌟 核心卡片渲染區 (含標籤自動轉換魔法)
    // ==========================================
    async Task RenderPostCard(SucculentCommunity.Models.Post item)
    {
        bool isAdmin = ViewBag.IsAdmin ?? false;
        bool isFavorited = false;
        if (User.Identity.IsAuthenticated && item.Favorites != null)
        {
            isFavorited = item.Favorites.Any(f => f.Member != null && f.Member.Account == User.Identity.Name);
        }

        // 🌟 正則表達式魔法：抓出所有 #開頭的標籤，並從原文字中剔除
        string rawContent = item.PostContent ?? "";
        var tagRegex = new Regex(@"#\S+");
        var tags = tagRegex.Matches(rawContent).Select(m => m.Value).ToList();
        var cleanContent = tagRegex.Replace(rawContent, "").Trim();

        <div class="col" id="post-card-@item.PostID">
            <div class="card h-100 shadow-sm border-0 rounded-4 overflow-hidden d-flex flex-column" style="transition: all 0.2s; cursor: pointer;"
                 onmouseover="this.style.transform='translateY(-5px)'" onmouseout="this.style.transform='translateY(0)'" onclick="location.href='/Posts/Details/@item.PostID'">

                @if (!string.IsNullOrEmpty(item.PostImage))
                {
                    <img src="~/images/posts/@item.PostImage" class="card-img-top" style="height: 200px; object-fit: cover;" alt="貼文封面">
                }
                else
                {
                    <div class="card-img-top d-flex align-items-center justify-content-center" style="height: 200px; background-color: #E6F2F2;">
                        <span class="fs-1 opacity-50">🪴</span>
                    </div>
                }

                <div class="card-body position-relative mt-2 flex-grow-1">
                    <div class="position-absolute top-0 start-0 translate-middle-y ms-3 d-flex gap-1 flex-wrap">

                        @if (item.IsPinned == "1")
                        {
                            <span class="badge rounded-pill shadow-sm px-2 py-1" style="background-color: #FFE5E5; color: #E63946; border: 1px solid #FF758C;">📌 置頂精華</span>
                        }

                        @if (item.PostType == "1")
                        {
                            <span class="badge rounded-pill bg-warning text-dark shadow-sm px-2 py-1">❓ 舉手發問</span>
                        }
                        else if (item.PostType == "2")
                        {
                            <span class="badge rounded-pill shadow-sm px-2 py-1" style="background-color: #B8D8BA; color: #fff;">📖 多肉日誌</span>
                        }
                        else if (item.PostType == "3")
                        {
                            <span class="badge rounded-pill bg-info text-white shadow-sm px-2 py-1">✨ 養護心得</span>
                        }

                        @if (item.Plant != null)
                        {
                            <span class="badge rounded-pill bg-light text-secondary border shadow-sm px-2 py-1">
                                🌱 @item.Plant.PlantNickname
                            </span>
                        }
                    </div>

                    <h5 class="card-title fw-bold mt-2 text-truncate" style="color: #4A6B6B;">@item.PostTitle</h5>

                    <p class="card-text text-secondary small mb-2" style="display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
                        @cleanContent
                    </p>

                    @if (tags.Any())
                    {
                        <div class="d-flex flex-wrap gap-1 mt-auto pt-2">
                            @foreach (var tag in tags)
                            {
                                <span class="badge rounded-pill shadow-sm" style="background-color: #F0F8FF; color: #5C8A8A; border: 1px solid #B8D8BA;">@tag</span>
                            }
                        </div>
                    }
                </div>

                <div class="card-footer bg-white border-0 pt-2 pb-3 d-flex justify-content-between align-items-center mt-auto">

                    <div class="d-flex align-items-center">
                        @{
                            var avatar = string.IsNullOrEmpty(item.Member?.Avatar) ? "default.jpg" : item.Member.Avatar;
                        }
                        <img src="~/images/avatars/@avatar" class="rounded-circle me-2" style="width: 25px; height: 25px; object-fit: cover;" />
                        <div>
                            <div class="small fw-bold" style="color: #5C8A8A; line-height: 1;">@item.Member?.Nickname</div>
                            <small class="text-muted" style="font-size: 0.7rem;">@item.CreatedTime.ToString("yyyy/MM/dd HH:mm")</small>
                        </div>
                    </div>

                    <div class="d-flex align-items-center gap-2">

                        <div class="text-muted small">
                            <span class="me-2">❤️ @(item.PostLikes?.Count ?? 0)</span>
                            <span>💬 @(item.Comments?.Where(c => !c.IsDeleted).Count() ?? 0)</span>
                        </div>

                        @if (isAdmin)
                        {
                            if (item.IsPinned == "1")
                            {
                                <button class="btn btn-sm rounded-circle shadow-sm toggle-pin-btn d-flex align-items-center justify-content-center" data-post-id="@item.PostID" style="width: 30px; height: 30px; transition: all 0.2s; background-color: #FFE5E5; border: 1px solid #FF758C;" title="取消置頂">
                                    <span class="pin-icon" style="font-size: 0.85rem;">📌</span>
                                </button>
                            }
                            else
                            {
                                <button class="btn btn-sm bg-white rounded-circle shadow-sm toggle-pin-btn d-flex align-items-center justify-content-center" data-post-id="@item.PostID" style="width: 30px; height: 30px; transition: all 0.2s; border: 1px solid #FF758C; color: #FF758C;" title="設為置頂">
                                    <span class="pin-icon" style="font-size: 0.85rem;">📌</span>
                                </button>
                            }
                        }

                        @if (isFavorited)
                        {
                            <button class="btn btn-sm rounded-circle shadow-sm toggle-fav-btn d-flex align-items-center justify-content-center" data-post-id="@item.PostID" style="width: 30px; height: 30px; transition: all 0.2s; background-color: #FFBD9D; color: white; border: 1px solid #FFBD9D;" title="取消收藏">
                                <span class="fav-icon" style="font-size: 0.85rem;">🔖</span>
                            </button>
                        }
                        else
                        {
                            <button class="btn btn-sm rounded-circle shadow-sm toggle-fav-btn d-flex align-items-center justify-content-center bg-white" data-post-id="@item.PostID" style="width: 30px; height: 30px; transition: all 0.2s; color: #FFBD9D; border: 1px solid #FFBD9D;" title="加入收藏">
                                <span class="fav-icon" style="font-size: 0.85rem;">⭐</span>
                            </button>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
}

<style>
    .custom-tabs .nav-link {
        color: #5C8A8A;
        background-color: #fff;
        border: 2px solid #E6F2F2;
    }

        .custom-tabs .nav-link:hover {
            background-color: #E6F2F2;
        }

        .custom-tabs .nav-link.active {
            color: #fff !important;
            background-color: #B8D8BA !important;
            border-color: #B8D8BA !important;
        }

        .custom-tabs .nav-link#pills-hot-tab.active {
            background-color: #dc3545 !important;
            border-color: #dc3545 !important;
            color: #fff !important;
        }
</style>

@section Scripts {
    <script>
        // 🌟 第一道防線：用 Razor 將後端的「登入狀態」傳遞給前端 JavaScript
        const isAuthenticated = @(User.Identity.IsAuthenticated ? "true" : "false");

        document.addEventListener("DOMContentLoaded", function () {
            let hash = window.location.hash;
            if (hash) {
                let triggerEl = document.querySelector('button[data-bs-target="' + hash + '"]');
                if (triggerEl) {
                    let tab = new bootstrap.Tab(triggerEl);
                    tab.show();
                }
            }
            let tabEls = document.querySelectorAll('button[data-bs-toggle="pill"]');
            tabEls.forEach(function (tabEl) {
                tabEl.addEventListener('shown.bs.tab', function (event) {
                    let target = event.target.getAttribute("data-bs-target");
                    history.replaceState(null, null, target);
                });
            });
        });

        function showToast(message, isSuccess = true) {
            const alertBox = document.createElement('div');
            alertBox.className = `alert alert-${isSuccess ? 'success' : 'danger'} rounded-pill text-center py-2 px-4 fw-bold shadow`;
            alertBox.style.cssText = 'position: fixed; top: 20px; left: 50%; transform: translateX(-50%); z-index: 9999; transition: opacity 0.5s ease;';
            alertBox.innerText = message;
            document.body.appendChild(alertBox);

            setTimeout(() => {
                alertBox.style.opacity = "0";
                setTimeout(() => alertBox.remove(), 500);
            }, 3000);
        }

        document.querySelectorAll('.toggle-fav-btn').forEach(btn => {
            btn.addEventListener('click', function(e) {
                e.stopPropagation();

                // 🌟 防呆攔截：如果沒登入，就不發送請求，直接跳出提示並引導登入！
                if (!isAuthenticated) {
                    alert("💡 請先登入才能收藏貼文喔！");
                    window.location.href = '/Members/Login';
                    return; // 終止後續的動作
                }

                const postId = this.getAttribute('data-post-id');
                const iconSpan = this.querySelector('.fav-icon');

                this.style.transform = "scale(0.8)";
                setTimeout(() => this.style.transform = "scale(1)", 150);

                fetch(`/Posts/ToggleFavorite?postId=${postId}`, { method: 'POST' })
                .then(res => {
                    // 🌟 第二道防護網：以防萬一還是被導向登入頁面，我們優雅處理
                    if (res.redirected) {
                        window.location.href = '/Members/Login';
                        throw new Error("Redirected");
                    }
                    if (!res.ok) throw new Error("伺服器回應錯誤");
                    return res.json();
                })
                .then(data => {
                    if (data.success) {
                        if (data.isFavorited) {
                            this.classList.remove('bg-white');
                            this.style.backgroundColor = '#FFBD9D';
                            this.style.color = 'white';
                            this.style.border = '1px solid #FFBD9D';
                            iconSpan.innerText = '🔖';
                            showToast('✅ 已加入我的收藏夾！', true);
                        } else {
                            this.style.backgroundColor = '#fff';
                            this.style.color = '#FFBD9D';
                            this.style.border = '1px solid #FFBD9D';
                            this.classList.add('bg-white');
                            iconSpan.innerText = '⭐';
                            showToast('✅ 已從收藏夾移除！', true);
                        }
                    } else {
                        alert(data.message);
                    }
                })
                .catch(error => {
                    if (error.message !== "Redirected") {
                        console.error("Fetch Error:", error);
                        alert("操作發生異常：" + error.message);
                    }
                });
            });
        });

        document.querySelectorAll('.toggle-pin-btn').forEach(btn => {
            btn.addEventListener('click', function(e) {
                e.stopPropagation();
                const postId = this.getAttribute('data-post-id');
                const btnElement = this;

                btnElement.style.transform = "scale(0.8)";
                setTimeout(() => btnElement.style.transform = "scale(1)", 150);

                fetch(`/Posts/TogglePin?postId=${postId}`, { method: 'POST' })
                .then(res => res.json())
                .then(data => {
                    if (data.success) {
                        showToast(data.message, true);
                        setTimeout(() => { window.location.reload(); }, 1500);
                    } else {
                        alert(data.message);
                    }
                })
                .catch(error => {
                    console.error("Fetch Error:", error);
                    alert("操作發生異常：" + error.message);
                });
            });
        });
    </script>
}