@model SucculentCommunity.ViewModels.CreatePostVM

@{
    ViewData["Title"] = "發布新貼文";
}

<div class="container mt-4 mb-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-sm border-0 rounded-4 p-4 p-md-5" style="background-color: #FAFAFA;">

                <div class="text-center mb-4">
                    <h2 class="fw-bold" style="color: #5C8A8A;">✍️ 寫點什麼吧</h2>
                    <p class="text-muted small">與園丁們分享你的多肉日常、養護心得或提出問題！</p>
                </div>

                <form asp-action="Create" enctype="multipart/form-data" id="createPostForm">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <h5 class="fw-bold mb-3" style="color: #7A8C8A;">你想發布什麼？</h5>
                    <div class="bg-white p-3 rounded-4 shadow-sm mb-4 mx-0 d-flex gap-3 flex-wrap">
                        <div class="form-check">
                            <input class="form-check-input post-type-radio" type="radio" asp-for="PostType" value="2" id="typeDiary" checked>
                            <label class="form-check-label fw-bold text-secondary" for="typeDiary">📖 多肉日誌</label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input post-type-radio" type="radio" asp-for="PostType" value="3" id="typeReview">
                            <label class="form-check-label fw-bold text-secondary" for="typeReview">✨ 養護心得</label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input post-type-radio" type="radio" asp-for="PostType" value="1" id="typeAsk">
                            <label class="form-check-label fw-bold text-secondary" for="typeAsk">❓ 舉手發問</label>
                        </div>
                    </div>

                    <div id="plantSection">
                        <h5 class="fw-bold mb-3" style="color: #7A8C8A;">這篇貼文的主角是？</h5>
                        <div class="bg-white p-4 rounded-4 shadow-sm mb-4 mx-0 border" style="border-color: #E6F2F2 !important;">

                            <div class="d-flex gap-4 mb-3 pb-3 border-bottom flex-wrap">
                                <div class="form-check">
                                    <input class="form-check-input plant-mode-radio" type="radio" name="PlantModeUI" value="none" id="modeNone" checked>
                                    <label class="form-check-label fw-bold text-secondary" for="modeNone">❌ 不指定植物 (純發文)</label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input plant-mode-radio" type="radio" name="PlantModeUI" value="old" id="modeOld">
                                    <label class="form-check-label fw-bold text-secondary" for="modeOld">🪴 選擇溫室裡的植物</label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input plant-mode-radio" type="radio" name="PlantModeUI" value="new" id="modeNew">
                                    <label class="form-check-label fw-bold text-secondary" for="modeNew">🌱 帶回了新多肉</label>
                                </div>
                            </div>

                            <input type="hidden" asp-for="IsNewPlant" id="ActualIsNewPlant" value="false" />

                            <div id="newPlantDiv" class="row" style="display: none;">
                                <div class="col-md-6 form-group mb-2">
                                    <label asp-for="SpeciesID" class="control-label fw-bold text-muted small mb-1">查閱圖鑑品種</label>
                                    <select asp-for="SpeciesID" asp-items="ViewBag.SpeciesID" class="form-select rounded-pill border-0 bg-light shadow-sm px-3">
                                        <option value="">-- 請選擇品種 (可不選) --</option>
                                    </select>
                                </div>
                                <div class="col-md-6 form-group mb-2">
                                    <label asp-for="PlantNickname" class="control-label fw-bold text-muted small mb-1">幫它取個可愛的暱稱吧 *</label>
                                    <input asp-for="PlantNickname" id="PlantNickname" class="form-control rounded-pill border-0 bg-light shadow-sm px-3" placeholder="例如：毛毛手" />
                                    <span asp-validation-for="PlantNickname" class="text-danger small"></span>
                                </div>
                                <div class="col-12 mt-2">
                                    <small class="text-muted">💡 發布這篇日誌後，系統會自動幫您建立這盆植物的專屬檔案喔！</small>
                                </div>
                            </div>

                            <div id="existingPlantDiv" class="row" style="display: none;">
                                <div class="col-md-12 form-group mb-2">
                                    <label asp-for="ExistingPlantID" class="control-label fw-bold text-muted small mb-1">選擇我的植物 *</label>
                                    <select asp-for="ExistingPlantID" id="ExistingPlantID" asp-items="ViewBag.ExistingPlantID" class="form-select rounded-pill border-0 bg-light shadow-sm px-3">
                                        <option value="">-- 點擊選擇 --</option>
                                    </select>
                                </div>
                            </div>

                        </div>
                    </div>

                    <h5 class="fw-bold mb-3 mt-4" style="color: #7A8C8A;">寫下你的分享：</h5>
                    <div class="bg-white p-3 rounded-4 shadow-sm mb-4 mx-0">
                        <div class="form-group mb-3">
                            <label asp-for="PostTitle" class="control-label fw-bold text-muted small mb-1">標題 *</label>
                            <input asp-for="PostTitle" class="form-control rounded-pill border-0 bg-light shadow-sm px-3" placeholder="下一個吸引人的標題吧..." />
                            <span asp-validation-for="PostTitle" class="text-danger small"></span>
                        </div>

                        <div id="careTagsArea" class="mb-3 p-3 rounded-4" style="background-color: #F8F9FA; border: 1px dashed #B8D8BA;">
                            <label class="control-label fw-bold text-muted small mb-2 d-block">✨ 加上專屬標籤 (可多選，發佈時會自動整理在文章末端喔！)</label>
                            <div class="d-flex flex-wrap gap-2">
                                <button type="button" class="btn btn-sm btn-outline-info rounded-pill fw-bold care-tag-btn" data-tag="#💧澆水">💧 澆水</button>
                                <button type="button" class="btn btn-sm btn-outline-warning rounded-pill fw-bold care-tag-btn" data-tag="#☀️日照">☀️ 日照</button>
                                <button type="button" class="btn btn-sm btn-outline-secondary rounded-pill fw-bold care-tag-btn" data-tag="#🪨換盆換土">🪨 換盆</button>
                                <button type="button" class="btn btn-sm btn-outline-success rounded-pill fw-bold care-tag-btn" data-tag="#💊施肥用藥">💊 施肥</button>
                                <button type="button" class="btn btn-sm btn-outline-danger rounded-pill fw-bold care-tag-btn" data-tag="#✂️修剪砍頭">✂️ 修剪</button>
                                <button type="button" class="btn btn-sm btn-outline-primary rounded-pill fw-bold care-tag-btn" data-tag="#📏測量生長">📏 測量</button>
                                <button type="button" class="btn btn-sm btn-outline-dark rounded-pill fw-bold care-tag-btn" data-tag="#🐛病蟲害">🐛 病蟲害</button>
                                <button type="button" class="btn btn-sm rounded-pill fw-bold care-tag-btn text-white" style="background-color: #FF758C; border-color: #FF758C;" data-tag="#🆘求救">🆘 求救</button>
                            </div>
                        </div>

                        <div class="form-group mb-3">
                            <label asp-for="PostContent" class="control-label fw-bold text-muted small mb-1">內容 *</label>
                            <textarea asp-for="PostContent" id="PostContent" class="form-control border-0 bg-light shadow-sm p-3" rows="6" style="border-radius: 20px;" placeholder="今天小肉肉有什麼變化呢？"></textarea>
                            <span asp-validation-for="PostContent" class="text-danger small"></span>
                        </div>

                        <div class="form-group mb-3">
                            <label class="control-label fw-bold text-muted small mb-2">📸 附上一張美照 (選填)</label>

                            <div class="mb-3 text-center d-none" id="previewContainer">
                                <img id="postImagePreview" src="#" class="rounded-4 shadow-sm" style="max-height: 250px; max-width: 100%; object-fit: cover; border: 3px solid #E6F2F2;" />
                            </div>

                            <input type="file" name="UploadImage" id="uploadImage" class="form-control rounded-pill border-0 bg-light px-3" accept="image/*" />
                        </div>

                        <div class="form-group">
                            <label class="control-label fw-bold text-muted small mb-2 me-2">隱私設定：</label>
                            <div class="form-check form-check-inline">
                                <input class="form-check-input" type="radio" asp-for="IsPublic" value="1" id="publicYes" checked>
                                <label class="form-check-label small" for="publicYes">🌍 公開分享</label>
                            </div>
                            <div class="form-check form-check-inline">
                                <input class="form-check-input" type="radio" asp-for="IsPublic" value="0" id="publicNo">
                                <label class="form-check-label small" for="publicNo">🔒 僅限自己</label>
                            </div>
                        </div>
                    </div>

                    <div class="d-flex justify-content-between align-items-center mt-4 pb-2">
                        <a href="#" class="btn btn-light rounded-pill px-4 text-muted fw-bold shadow-sm smart-back-btn" data-fallback="/Home/Index">取消返回</a>
                        <button type="submit" class="btn rounded-pill px-5 text-white fw-bold shadow-sm" style="background-color: #5C8A8A;">🚀 正式發布</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<style>
    /* 讓求救按鈕被選中時有更明顯的特效 */
    .care-tag-btn.active[data-tag="#🆘求救"] {
        background-color: #dc3545 !important;
        border-color: #dc3545 !important;
        box-shadow: 0 0 10px rgba(220, 53, 69, 0.5);
    }
</style>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        $(document).ready(function () {

            // ==========================================
            // 魔法 1：監聽「貼文類型」的切換
            // ==========================================
            $('.post-type-radio').change(function () {
                var selectedType = $(this).val();

                // 🌟 現在標籤區塊 (#careTagsArea) 永遠保持展開了！
                // 只有植物區塊會根據是否為「舉手發問(1)」來決定要不要自動收合
                if (selectedType === '1') {
                    $('#plantSection').slideUp(300);
                } else {
                    $('#plantSection').slideDown(300);
                }
            });

            // ==========================================
            // 魔法 2：監聽「植物模式」的 3 種切換
            // ==========================================
            $('.plant-mode-radio').change(function () {
                var mode = $(this).val();

                if (mode === 'none') {
                    // ❌ 不指定植物
                    $('#ActualIsNewPlant').val('false');
                    $('#existingPlantDiv').slideUp(300);
                    $('#newPlantDiv').slideUp(300);
                    $('#ExistingPlantID').val('');
                    $('#PlantNickname').val('');
                } else if (mode === 'old') {
                    // 🪴 選擇現有植物
                    $('#ActualIsNewPlant').val('false');
                    $('#newPlantDiv').hide();
                    $('#existingPlantDiv').fadeIn(300);
                } else if (mode === 'new') {
                    // 🌱 建立新植物
                    $('#ActualIsNewPlant').val('true');
                    $('#existingPlantDiv').hide();
                    $('#newPlantDiv').fadeIn(300);
                }
            });

            // 初始化：確保如果一開始選「不指定植物」，區塊是收起來的
            if ($('#modeNone').is(':checked')) {
                $('#existingPlantDiv').hide();
                $('#newPlantDiv').hide();
            }

            // ==========================================
            // 魔法 3：點擊「養護標籤」變色 (多選按鈕)
            // ==========================================
            $('.care-tag-btn').click(function() {
                $(this).toggleClass('active');
                $(this).css("transform", "scale(0.9)");
                setTimeout(() => $(this).css("transform", "scale(1)"), 150);
            });

            // 🚀 送出表單前：自動把有亮起來的標籤收集起來，加到文章末尾！
            $('#createPostForm').submit(function() {
                let activeTags = [];
                $('.care-tag-btn.active').each(function() {
                    activeTags.push($(this).data('tag'));
                });

                if (activeTags.length > 0) {
                    let contentBox = $('#PostContent');
                    let currentContent = contentBox.val();
                    let tagsString = activeTags.join(' ');

                    // 防呆：確認還沒被加過標籤，才加在最後面
                    if (!currentContent.endsWith(tagsString)) {
                        contentBox.val(currentContent + "\n\n" + tagsString);
                    }
                }
            });

            // ==========================================
            // 魔法 4：上傳圖片即時預覽功能
            // ==========================================
            $('#uploadImage').change(function (e) {
                const file = e.target.files[0];
                if (file) {
                    const reader = new FileReader();
                    reader.onload = function (event) {
                        $('#postImagePreview').attr('src', event.target.result);
                        $('#previewContainer').removeClass('d-none');
                    }
                    reader.readAsDataURL(file);
                } else {
                    $('#postImagePreview').attr('src', '#');
                    $('#previewContainer').addClass('d-none');
                }
            });

        });
    </script>
}